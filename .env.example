# Database (Neon Postgres)
# DATABASE_URL — pooled connection (host contains "-pooler"). Use for app runtime (Vercel, worker).
# Optional pool tuning (auto-applied in lib/db/prisma.ts if omitted): connection_limit=5 (next), 3 (worker)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# DIRECT_URL — direct connection (no "-pooler" in host). Use for prisma migrate / db push only.
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/db?sslmode=require

# Queue (Railway Redis — co-located with worker)
REDIS_URL=redis://default:password@host:port

# AI (OpenRouter — single key for all agents, including Perplexity Sonar research)
OPENROUTER_API_KEY=sk-or-v1-...
# Set to 0 to disable web search for thin marketing briefs (dev only)
MARKETING_SEARCH_ENABLED=1

# Storage (Vercel Blob — prod; omit for local-only dev)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Pipeline — in dev, jobs run in-process unless you start the worker (npm run dev:all)
# Set PIPELINE_WORKER=1 when running the BullMQ worker alongside next dev
# Run multiple posts in parallel (one BullMQ job per post after photo submit)
PIPELINE_CONCURRENCY=3

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
