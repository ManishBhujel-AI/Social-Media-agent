{
  "name": "brewline-content-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "PIPELINE_WORKER=1 tsx --env-file-if-exists=.env scripts/worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file-if-exists=.env scripts/seed.ts",
    "test:image": "tsx --env-file-if-exists=.env scripts/test-image-gen.ts",
    "test:json": "tsx scripts/test-json-parse.ts",
    "test:agent-loop": "tsx scripts/test-agent-loop.ts",
    "test:page-cache": "tsx scripts/test-page-cache.ts",
    "pipeline:once": "tsx --env-file-if-exists=.env scripts/run-pipeline-once.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.1.0",
    "@vercel/blob": "^0.27.0",
    "bullmq": "^5.34.5",
    "cheerio": "^1.2.0",
    "framer-motion": "^11.15.0",
    "ioredis": "^5.4.2",
    "next": "14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.21",
    "postcss": "^8",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
